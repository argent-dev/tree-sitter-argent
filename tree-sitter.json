{
  "grammars": [
    {
      "name": "argent",
      "camelcase": "Argent",
      "scope": "source.argent",
      "path": ".",
      "file-types": [
        "ag"
      ],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm",
      "locals": "queries/locals.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Argent",
    "links": {
      "repository": "https://github.com/argent-dev/tree-sitter-argent"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
